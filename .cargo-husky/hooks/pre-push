#!/bin/sh
# pre-push — push 前の品質ゲート
# cargo-husky (user-hooks フィーチャー) によって .git/hooks/pre-push にインストールされる。
# cargo test を一度実行すれば自動セットアップされる。

set -e

echo "🔍 [pre-push] フォーマットチェック..."
cargo fmt --all -- --check

echo "📎 [pre-push] Clippy (警告ゼロ強制)..."
cargo clippy --workspace -- -D warnings

echo "🧪 [pre-push] テスト実行..."
cargo test --workspace

echo "✅ [pre-push] 全チェック通過。push を続行します。"
